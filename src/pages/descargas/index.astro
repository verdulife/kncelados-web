---
import Layout from "@/layouts/Layout.astro";
---

<Fragment slot="head">
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.kncelados.com/descargas" />
  <meta property="og:title" content="Descargas | Kncelados" />
  <meta
    property="og:description"
    content="Próximamente tendrás aquí todo el material oficial de Kncelados para descargar: PDFs, wallpapers, audio y ZIP especiales."
  />
  <meta property="og:image" content="https://www.kncelados.com/logo-512.jpg" />
  <meta name="twitter:title" content="Descargas | Kncelados" />
  <meta
    name="twitter:description"
    content="Próximamente tendrás aquí todo el material oficial de Kncelados para descargar: PDFs, wallpapers, audio y ZIP especiales."
  />
  <meta name="twitter:image" content="https://www.kncelados.com/logo-512.jpg" />
  <link rel="canonical" href="https://www.kncelados.com/descargas" />
</Fragment>

<Layout
  title="Descargas | Kncelados"
  description="Próximamente tendrás aquí todo el material oficial de Kncelados para descargar: PDFs, wallpapers, audio y ZIP especiales."
>
  <section
    class="flex min-h-[80vh] flex-1 flex-col items-center gap-8 px-4 pb-20 text-center"
  >
    <h1 class="mt-48 max-w-3xl text-4xl lg:text-7xl">Descargas</h1>

    <p class="max-w-3xl text-lg text-gray-300 lg:text-xl">
      Descarga nuestros PDFs con arte oficial de Kncelados. Material listo para
      compartir, imprimir y usar.
    </p>

    <div class="mt-12 grid w-full max-w-5xl gap-4 sm:grid-cols-2">
      <article
        class="flex items-center overflow-hidden rounded-3xl border border-white/10 bg-white/5"
      >
        <div
          class="flex min-h-[320px] w-full flex-col items-center lg:min-h-[200px] lg:flex-row"
        >
          <div
            class="flex h-64 w-full items-center justify-center p-4 lg:h-auto lg:w-1/2"
          >
            <img
              src="/descargas/no-vendo.webp"
              alt="Vista previa No Vendo"
              class="max-h-full max-w-full object-contain"
            />
          </div>
          <div
            class="flex w-full flex-1 flex-col items-center justify-center p-8 text-center lg:items-start lg:justify-start lg:text-left"
          >
            <h2 class="text-2xl">No Vendo</h2>
            <a
              href="/descargas/no-vendo.pdf"
              download
              class="bg-knc-red mt-6 inline-flex rounded-xl px-4 py-3 text-sm font-semibold transition hover:scale-105"
            >
              Descargar PDF
            </a>
          </div>
        </div>
      </article>

      <article
        class="flex items-center overflow-hidden rounded-3xl border border-white/10 bg-white/5"
      >
        <div
          class="flex min-h-[320px] w-full flex-col items-center lg:min-h-[200px] lg:flex-row"
        >
          <div
            class="flex h-64 w-full items-center justify-center p-4 lg:h-64 lg:w-1/2"
          >
            <img
              src="/descargas/yoaparcomal.webp"
              alt="Vista previa Yo Aparco Mal"
              class="max-h-full max-w-full object-contain"
            />
          </div>
          <div
            class="flex w-full flex-1 flex-col items-center justify-center p-8 text-center lg:items-start lg:justify-start lg:text-left"
          >
            <h2 class="text-2xl">Yo Aparco Mal</h2>
            <a
              href="/descargas/yoaparcomal.pdf"
              download
              class="bg-knc-red mt-6 inline-flex rounded-xl px-4 py-3 text-sm font-semibold transition hover:scale-105"
            >
              Descargar PDF
            </a>
          </div>
        </div>
      </article>
    </div>
  </section>
</Layout>
